@using DMB.Core.Evaluator
@using DMB.Core
@using System.Globalization

@inject ExpressionEvaluator Evaluator
@inject ModuleDocumentCore ModuleDocument

@if (this.Visible)
{
    <MudDataGrid T="DatasetRowModelCore" Items="Rows"
                 Striped="Model.Striped"
                 Bordered="Model.Bordered"
                 Hover="Model.Hover"
                 Dense="Model.Dense">
        
        <ToolBarContent>
            @if (this.Model.ShowToolbar && this.Model.ToolBarGrid != null) 
            {
                <GridRenderer Grid="this.Model.ToolBarGrid" CurrentRow="CurrentRow" />
            }
        </ToolBarContent>
        <Columns>
            @{
                var ds = this.GetDataset();
                if (ds != null)
                {
                    foreach (var item in this.Model.Columns)
                    {
                        var field = ds.Fields.FirstOrDefault(p => p.Name == item.Field);
                        if (field != null)
                        {
                            @if (this.HasCellTemplate(item))
                            {
                                if (field.DataType == FieldDataType.String)
                                {
                                    <PropertyColumn Title="@(ExpressionablePropertyResolver<string?>.Resolve(item.HeaderText, Evaluator))"
                                                    Property="@(x => Convert.ToString(x.Values[field.Name]))"
                                                    Filterable="item.EnableFitering"
                                                    Sortable="item.EnableSorting"
                                                    Hidden="@(!ExpressionablePropertyResolver<bool>.Resolve(item.Visible, Evaluator))"
                                                    Format="@(this.GetColumnFormat(item))">

                                        <CellTemplate Context="context">
                                            <GridRenderer Grid="item.CellTemplate!.Content" CurrentRow="context.Item" />
                                        </CellTemplate>
                                    </PropertyColumn>
                                }
                                else if (field.DataType == FieldDataType.DateTime)
                                {
                                    <PropertyColumn Title="@(ExpressionablePropertyResolver<string?>.Resolve(item.HeaderText, Evaluator))"
                                                    Property="@(x => Convert.ToDateTime(x.Values[field.Name], CultureInfo.InvariantCulture))"
                                                    Filterable="item.EnableFitering"
                                                    Sortable="item.EnableSorting"
                                                    Hidden="@(!ExpressionablePropertyResolver<bool>.Resolve(item.Visible, Evaluator))"
                                                    Format="@(this.GetColumnFormat(item))">

                                        <CellTemplate Context="context">
                                            <GridRenderer Grid="item.CellTemplate!.Content" CurrentRow="context.Item" />
                                        </CellTemplate>
                                    </PropertyColumn>

                                }
                                else if (field.DataType == FieldDataType.DateOnly)
                                {
                                    <PropertyColumn Title="@(ExpressionablePropertyResolver<string?>.Resolve(item.HeaderText, Evaluator))"
                                                    Property="@(x => DateOnly.FromDateTime(Convert.ToDateTime(x.Values[field.Name], CultureInfo.InvariantCulture)))"
                                                    Filterable="item.EnableFitering"
                                                    Sortable="item.EnableSorting"
                                                    Hidden="@(!ExpressionablePropertyResolver<bool>.Resolve(item.Visible, Evaluator))"
                                                    Format="@(this.GetColumnFormat(item))">

                                        <CellTemplate Context="context">
                                            <GridRenderer Grid="item.CellTemplate!.Content" CurrentRow="context.Item" />
                                        </CellTemplate>
                                    </PropertyColumn>
                                }
                                else if (field.DataType == FieldDataType.TimeOnly)
                                {
                                    <PropertyColumn Title="@(ExpressionablePropertyResolver<string?>.Resolve(item.HeaderText, Evaluator))"
                                                    Property="@(x => TimeOnly.FromDateTime(Convert.ToDateTime(x.Values[field.Name], CultureInfo.InvariantCulture)))"
                                                    Filterable="item.EnableFitering"
                                                    Sortable="item.EnableSorting"
                                                    Hidden="@(!ExpressionablePropertyResolver<bool>.Resolve(item.Visible, Evaluator))"
                                                    Format="@(this.GetColumnFormat(item))">

                                        <CellTemplate Context="context">
                                            <GridRenderer Grid="item.CellTemplate!.Content" CurrentRow="context.Item" />
                                        </CellTemplate>

                                    </PropertyColumn>
                                }
                                else if (field.DataType == FieldDataType.Integer)
                                {
                                    <PropertyColumn Title="@(ExpressionablePropertyResolver<string?>.Resolve(item.HeaderText, Evaluator))"
                                                    Property="@(x => Convert.ToInt32(x.Values[field.Name]))"
                                                    Filterable="item.EnableFitering"
                                                    Sortable="item.EnableSorting"
                                                    Hidden="@(!ExpressionablePropertyResolver<bool>.Resolve(item.Visible, Evaluator))"
                                                    Format="@(this.GetColumnFormat(item))">

                                        <CellTemplate Context="context">
                                            <GridRenderer Grid="item.CellTemplate!.Content" CurrentRow="context.Item" />
                                        </CellTemplate>
                                    </PropertyColumn>
                                }
                                else if (field.DataType == FieldDataType.Float)
                                {
                                    <PropertyColumn Title="@(ExpressionablePropertyResolver<string?>.Resolve(item.HeaderText, Evaluator))"
                                                    Property="@(x => Convert.ToDouble(x.Values[field.Name]))"
                                                    Filterable="item.EnableFitering"
                                                    Sortable="item.EnableSorting"
                                                    Hidden="@(!ExpressionablePropertyResolver<bool>.Resolve(item.Visible, Evaluator))"
                                                    Format="@(this.GetColumnFormat(item))">

                                        <CellTemplate Context="context">
                                            <GridRenderer Grid="item.CellTemplate!.Content" CurrentRow="context.Item" />
                                        </CellTemplate>

                                    </PropertyColumn>
                                }
                                else if (field.DataType == FieldDataType.Boolean)
                                {
                                    <PropertyColumn Title="@(ExpressionablePropertyResolver<string?>.Resolve(item.HeaderText, Evaluator))"
                                                    Property="@(x => Convert.ToBoolean(x.Values[field.Name]))"
                                                    Filterable="item.EnableFitering"
                                                    Sortable="item.EnableSorting"
                                                    Hidden="@(!ExpressionablePropertyResolver<bool>.Resolve(item.Visible, Evaluator))"
                                                    Format="@(this.GetColumnFormat(item))">

                                        <CellTemplate Context="context">
                                            <GridRenderer Grid="item.CellTemplate!.Content" />
                                        </CellTemplate>
                                    </PropertyColumn>
                                }
                            }
                            else
                            {
                                if (field.DataType == FieldDataType.String)
                                {
                                    <PropertyColumn Title="@(ExpressionablePropertyResolver<string?>.Resolve(item.HeaderText, Evaluator))"
                                                    Property="@(x => Convert.ToString(x.Values[field.Name]))"
                                                    Filterable="item.EnableFitering"
                                                    Sortable="item.EnableSorting"
                                                    Hidden="@(!ExpressionablePropertyResolver<bool>.Resolve(item.Visible, Evaluator))"
                                                    Format="@(this.GetColumnFormat(item))" />
                                }
                                else if (field.DataType == FieldDataType.DateTime)
                                {
                                    <PropertyColumn Title="@(ExpressionablePropertyResolver<string?>.Resolve(item.HeaderText, Evaluator))"
                                                    Property="@(x => Convert.ToDateTime(x.Values[field.Name], CultureInfo.InvariantCulture))"
                                                    Filterable="item.EnableFitering"
                                                    Sortable="item.EnableSorting"
                                                    Hidden="@(!ExpressionablePropertyResolver<bool>.Resolve(item.Visible, Evaluator))"
                                                    Format="@(this.GetColumnFormat(item))" />

                                }
                                else if (field.DataType == FieldDataType.DateOnly)
                                {
                                    <PropertyColumn Title="@(ExpressionablePropertyResolver<string?>.Resolve(item.HeaderText, Evaluator))"
                                                    Property="@(x => DateOnly.FromDateTime(Convert.ToDateTime(x.Values[field.Name], CultureInfo.InvariantCulture)))"
                                                    Filterable="item.EnableFitering"
                                                    Sortable="item.EnableSorting"
                                                    Hidden="@(!ExpressionablePropertyResolver<bool>.Resolve(item.Visible, Evaluator))"
                                                    Format="@(this.GetColumnFormat(item))">

                                    </PropertyColumn>
                                }
                                else if (field.DataType == FieldDataType.TimeOnly)
                                {
                                    <PropertyColumn Title="@(ExpressionablePropertyResolver<string?>.Resolve(item.HeaderText, Evaluator))"
                                                    Property="@(x => TimeOnly.FromDateTime(Convert.ToDateTime(x.Values[field.Name], CultureInfo.InvariantCulture)))"
                                                    Filterable="item.EnableFitering"
                                                    Sortable="item.EnableSorting"
                                                    Hidden="@(!ExpressionablePropertyResolver<bool>.Resolve(item.Visible, Evaluator))"
                                                    Format="@(this.GetColumnFormat(item))">

                                    </PropertyColumn>
                                }
                                else if (field.DataType == FieldDataType.Integer)
                                {
                                    <PropertyColumn Title="@(ExpressionablePropertyResolver<string?>.Resolve(item.HeaderText, Evaluator))"
                                                    Property="@(x => Convert.ToInt32(x.Values[field.Name]))"
                                                    Filterable="item.EnableFitering"
                                                    Sortable="item.EnableSorting"
                                                    Hidden="@(!ExpressionablePropertyResolver<bool>.Resolve(item.Visible, Evaluator))"
                                                    Format="@(this.GetColumnFormat(item))">

                                    </PropertyColumn>
                                }
                                else if (field.DataType == FieldDataType.Float)
                                {
                                    <PropertyColumn Title="@(ExpressionablePropertyResolver<string?>.Resolve(item.HeaderText, Evaluator))"
                                                    Property="@(x => Convert.ToDouble(x.Values[field.Name]))"
                                                    Filterable="item.EnableFitering"
                                                    Sortable="item.EnableSorting"
                                                    Hidden="@(!ExpressionablePropertyResolver<bool>.Resolve(item.Visible, Evaluator))"
                                                    Format="@(this.GetColumnFormat(item))">

                                    </PropertyColumn>
                                }
                                else if (field.DataType == FieldDataType.Boolean)
                                {
                                    <PropertyColumn Title="@(ExpressionablePropertyResolver<string?>.Resolve(item.HeaderText, Evaluator))"
                                                    Property="@(x => Convert.ToBoolean(x.Values[field.Name]))"
                                                    Filterable="item.EnableFitering"
                                                    Sortable="item.EnableSorting"
                                                    Hidden="@(!ExpressionablePropertyResolver<bool>.Resolve(item.Visible, Evaluator))"
                                                    Format="@(this.GetColumnFormat(item))">

                                    </PropertyColumn>
                                }
                            }
                        }
                    }
                }
            }
        </Columns>

    </MudDataGrid>
}

@code {
    private DatasetModelCore<DatasetFieldModelCore>? _dataset;

    [Parameter]
    public DatasetRowModelCore? CurrentRow { get; set; }

    [Parameter, EditorRequired]
    public DataGridModelCore<DataGridColumnModelCore> Model { get; set; } = default!;


    public List<DatasetRowModelCore> Rows { get; set; } = new();

    protected override void OnInitialized()
    {
        this.LoadData();
        base.OnInitialized();
    }

    private bool Visible
    {
        get
        {
            return ExpressionablePropertyResolver<bool>.Resolve(this.Model.Visible, Evaluator);
        }
    }

    private void LoadData()
    {
        if (this.Model.ModuleDocumentCore is null || string.IsNullOrWhiteSpace(this.Model.Dataset))
            return;

        var dataset = StaticDataResolver.CalculateData(this.Model.Dataset, this.Model.ModuleDocumentCore, this.Evaluator);
        this.Rows = dataset.DataRows;
    }

    private DatasetModelCore<DatasetFieldModelCore>? GetDataset()
    {
        if (this._dataset == null)
        {
            this._dataset = this.ModuleDocument.AllItems
                .OfType<DatasetModelCore<DatasetFieldModelCore>>()
                .Cast<DatasetModelCore<DatasetFieldModelCore>>()
                .FirstOrDefault(p => p.Id == this.Model.Dataset);
        }
        return this._dataset;
    }

    private string? GetColumnFormat(DataGridColumnModelCore column)
    {
        var format = ExpressionablePropertyResolver<string?>.Resolve(column.Format, Evaluator);
        return string.IsNullOrWhiteSpace(format) ? null : format;
    }

    private bool HasCellTemplate(DataGridColumnModelCore column)
    {
        return column.CellTemplate is not null
               && column.CellTemplate.Enabled
               && column.CellTemplate.Content is not null;
    }

    private RenderFragment RenderCellTemplate(DataGridColumnModelCore column, DatasetRowModelCore row) => builder =>
    {
        if (column.CellTemplate?.Content is null)
            return;

        builder.OpenComponent(0, typeof(GridRenderer));
        builder.AddAttribute(1, "Model", column.CellTemplate.Content);
        builder.AddAttribute(2, "CurrentRow", row);
        builder.CloseComponent();
    };
}
